{
    "name": "webcoast/migrator-from-dce",
    "type": "typo3-cms-extension",
    "description": "DCE provider for Migrator extension",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "Thorben Nissen",
            "email": "thorben@webcoast.dk"
        }
    ],
    "extra": {
        "typo3/cms": {
            "extension-key": "migrator_from_dce"
        },
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    },
    "require": {
        "typo3/cms-core": "^13.4",
        "webcoast/migrator": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "WEBcoast\\MigratorFromDce\\": "Classes"
        }
    }
}
